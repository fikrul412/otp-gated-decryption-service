	$(MAKE) $(MAKESILENT) -f CMakeFiles\EncryptionAPI.dir\build.make CMakeFiles/EncryptionAPI.dir/src/utlis/json_utils.c.obj
.PHONY : src/utlis/json_utils.c.obj

src/utlis/json_utils.i: src/utlis/json_utils.c.i
.PHONY : src/utlis/json_utils.i

# target to preprocess a source file
src/utlis/json_utils.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\EncryptionAPI.dir\build.make CMakeFiles/EncryptionAPI.dir/src/utlis/json_utils.c.i
.PHONY : src/utlis/json_utils.c.i

src/utlis/json_utils.s: src/utlis/json_utils.c.s
.PHONY : src/utlis/json_utils.s

# target to generate assembly for a file
src/utlis/json_utils.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\EncryptionAPI.dir\build.make CMakeFiles/EncryptionAPI.dir/src/utlis/json_utils.c.s
.PHONY : src/utlis/json_utils.c.s

